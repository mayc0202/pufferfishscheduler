<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pufferfishscheduler.dao.mapper.TransTaskLogMapper">

    <resultMap id="BaseResultMap" type="com.pufferfishscheduler.dao.entity.TransTaskLog">
        <id column="id" jdbcType="VARCHAR" property="id"/>
        <result column="task_id" jdbcType="INTEGER" property="taskId"/>
        <result column="status" jdbcType="VARCHAR" property="status"/>
        <result column="executing_type" jdbcType="VARCHAR" property="executingType"/>
        <result column="data_volume" jdbcType="BIGINT" property="dataVolume"/>
        <result column="lines_read" jdbcType="BIGINT" property="linesRead"/>
        <result column="lines_written" jdbcType="BIGINT" property="linesWritten"/>
        <result column="lines_updated" jdbcType="BIGINT" property="linesUpdated"/>
        <result column="lines_input" jdbcType="BIGINT" property="linesInput"/>
        <result column="lines_output" jdbcType="BIGINT" property="linesOutput"/>
        <result column="lines_rejected" jdbcType="BIGINT" property="linesRejected"/>
        <result column="lines_errors" jdbcType="BIGINT" property="linesErrors"/>
        <result column="reason" jdbcType="LONGVARCHAR" property="reason"/>
        <result column="flow_image" jdbcType="LONGVARCHAR" property="flowImage"/>
        <result column="parameters" jdbcType="LONGVARCHAR" property="parameters"/>
        <result column="log_detail" jdbcType="LONGVARCHAR" property="logDetail"/>
        <result column="start_time" jdbcType="TIMESTAMP" property="startTime"/>
        <result column="end_time" jdbcType="TIMESTAMP" property="endTime"/>
        <result column="duration_seconds" jdbcType="INTEGER" property="durationSeconds"/>
        <result column="created_by" jdbcType="VARCHAR" property="createdBy"/>
        <result column="created_time" jdbcType="TIMESTAMP" property="createdTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, task_id, status, executing_type, data_volume, lines_read, lines_written, lines_updated,
        lines_input, lines_output, lines_rejected, lines_errors, reason, flow_image, parameters, log_detail,
        start_time, end_time, duration_seconds, created_by, created_time
    </sql>

    <select id="selectTaskLogList" resultType="com.pufferfishscheduler.domain.vo.collect.TransTaskLogVo">
        SELECT
        lg.*,
        ts.name AS taskName,
        fl.name AS flowName,
        fl.config AS flowConfig
        FROM trans_task_log lg
        INNER JOIN trans_task ts ON lg.task_id = ts.id AND ts.deleted = FALSE
        INNER JOIN trans_flow fl ON fl.id = ts.flow_id AND fl.deleted = FALSE
        <where>
            <if test="params.taskName != null and params.taskName != ''">
                AND ts.name LIKE CONCAT('%', #{params.taskName}, '%')
            </if>
            <if test="params.status != null and params.status != ''">
                AND lg.status = #{params.status}
            </if>
            <if test="params.startTime != null and params.startTime != ''">
                AND lg.start_time >= #{params.startTime}
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                AND lg.end_time &lt;= #{params.endTime}
            </if>
        </where>
        ORDER BY lg.start_time DESC
    </select>

    <select id="detail" resultType="com.pufferfishscheduler.domain.vo.collect.TransTaskLogVo">
        SELECT lg.*,
               ts.name   AS taskName,
               fl.name   AS flowName,
               fl.config AS flowConfig
        FROM trans_task_log lg
                 INNER JOIN trans_task ts ON lg.task_id = ts.id AND ts.deleted = FALSE
                 INNER JOIN trans_flow fl ON fl.id = ts.flow_id AND fl.deleted = FALSE
        where lg.id = #{id}
    </select>

</mapper>

