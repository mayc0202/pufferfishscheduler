<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <artifactId>pufferfishscheduler</artifactId>
        <groupId>com.pufferfishscheduler</groupId>
        <version>1.0-SNAPSHOT</version>
    </parent>
    <modelVersion>4.0.0</modelVersion>

    <artifactId>pufferfishscheduler-worker</artifactId>
    <version>1.0-SNAPSHOT</version>

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
        <maven.compiler.encoding>UTF-8</maven.compiler.encoding>
    </properties>

    <dependencies>

        <!-- pufferfishscheduler-common -->
        <dependency>
            <groupId>com.pufferfishscheduler.common</groupId>
            <artifactId>pufferfishscheduler-common</artifactId>
            <exclusions>
                <exclusion>
                    <groupId>com.pufferfishscheduler.domain</groupId>
                    <artifactId>pufferfishscheduler-domain</artifactId>
                </exclusion>
            </exclusions>
            <version>1.0.0</version>
        </dependency>

        <!-- dao -->
        <dependency>
            <groupId>com.pufferfishscheduler.dao</groupId>
            <artifactId>pufferfishscheduler-dao</artifactId>
            <version>1.0.0</version>
        </dependency>

        <!-- Kettle 转换引擎与步骤构造器（与 Master 共用） -->
        <dependency>
            <groupId>com.pufferfishscheduler.trans</groupId>
            <artifactId>pufferfishscheduler-trans-core</artifactId>
            <version>1.0.0</version>
        </dependency>

        <!-- api contract (DTO / SPI) -->
        <dependency>
            <groupId>com.pufferfishscheduler</groupId>
            <artifactId>pufferfishscheduler-api</artifactId>
            <version>1.0-SNAPSHOT</version>
        </dependency>

        <!-- dubbo -->
        <dependency>
            <groupId>org.apache.dubbo</groupId>
            <artifactId>dubbo-spring-boot-starter</artifactId>
        </dependency>

        <!-- mysql -->
        <dependency>
            <groupId>mysql</groupId>
            <artifactId>mysql-connector-java</artifactId>
        </dependency>

        <!-- c3p0 -->
        <dependency>
            <groupId>com.mchange</groupId>
            <artifactId>c3p0</artifactId>
        </dependency>

        <!-- curator (Dubbo ZK metadata center 需要) -->
        <dependency>
            <groupId>org.apache.curator</groupId>
            <artifactId>curator-framework</artifactId>
        </dependency>
        <dependency>
            <groupId>org.apache.curator</groupId>
            <artifactId>curator-recipes</artifactId>
        </dependency>
        <dependency>
            <groupId>org.apache.curator</groupId>
            <artifactId>curator-x-discovery</artifactId>
        </dependency>

        <!-- zookeeper (Dubbo uses ZK) -->
        <dependency>
            <groupId>org.apache.zookeeper</groupId>
            <artifactId>zookeeper</artifactId>
        </dependency>

        <!-- Kafka (consume dispatch messages) -->
        <dependency>
            <groupId>org.apache.kafka</groupId>
            <artifactId>kafka-clients</artifactId>
        </dependency>

        <!-- Kettle核心依赖 -->
        <dependency>
            <groupId>pentaho-kettle</groupId>
            <artifactId>kettle-core</artifactId>
        </dependency>

        <dependency>
            <groupId>pentaho-kettle</groupId>
            <artifactId>kettle-engine</artifactId>
        </dependency>

        <dependency>
            <groupId>pentaho-kettle</groupId>
            <artifactId>kettle-dbdialog</artifactId>
        </dependency>

        <!-- Kettle 使用的 Guava 需 failureaccess，否则 KettleEnvironment.init 报 InternalFutureFailureAccess -->
        <dependency>
            <groupId>com.google.guava</groupId>
            <artifactId>failureaccess</artifactId>
        </dependency>

        <!-- Kettle SubtransExecutor 依赖 Jetty 9 ConcurrentHashSet；显式声明以覆盖 kettle-core/Spring 传递的 Jetty 12 -->
        <dependency>
            <groupId>org.eclipse.jetty</groupId>
            <artifactId>jetty-util</artifactId>
        </dependency>

        <!-- 数据清洗插件：
            1) 作为 master 依赖用于构建流程配置时实例化 StepMeta
            2) 运行时仍通过解压分发包到 plugins/steps 供 Kettle 扫描 -->
        <dependency>
            <groupId>com.pufferfishscheduler.plugin</groupId>
            <artifactId>pfs-dataclean-plugin</artifactId>
            <version>1.0.0</version>
        </dependency>

        <!-- Debezium报文解析插件 -->
        <dependency>
            <groupId>com.pufferfishscheduler.plugin</groupId>
            <artifactId>pfs-debeziumjson-plugin</artifactId>
            <version>1.0.0</version>
        </dependency>

        <!-- 数据过滤插件 -->
        <dependency>
            <groupId>com.pufferfishscheduler.plugin</groupId>
            <artifactId>pfs-filter-plugin</artifactId>
            <version>1.0.0</version>
        </dependency>

        <!-- FTP下载插件 -->
        <dependency>
            <groupId>com.pufferfishscheduler.plugin</groupId>
            <artifactId>pfs-ftpdownload-plugin</artifactId>
            <version>1.0.0</version>
        </dependency>

        <!-- FTP上传插件 -->
        <dependency>
            <groupId>com.pufferfishscheduler.plugin</groupId>
            <artifactId>pfs-ftpupload-plugin</artifactId>
            <version>1.0.0</version>
        </dependency>

        <!-- Doris插件 -->
        <dependency>
            <groupId>com.pufferfishscheduler.plugin</groupId>
            <artifactId>pfs-doris-plugin</artifactId>
            <version>1.0.0</version>
        </dependency>

        <!-- KafkaConsumer插件 -->
        <dependency>
            <groupId>com.pufferfishscheduler.plugin</groupId>
            <artifactId>pfs-kafkaconsumer-plugin</artifactId>
            <version>1.0.0</version>
        </dependency>

        <!-- KafkaProducer插件 -->
        <dependency>
            <groupId>com.pufferfishscheduler.plugin</groupId>
            <artifactId>pfs-kafkaproducer-plugin</artifactId>
            <version>1.0.0</version>
        </dependency>

        <!-- RabbitMQ 消费/生产插件 -->
        <dependency>
            <groupId>com.pufferfishscheduler.plugin</groupId>
            <artifactId>pfs-rabbitmqconsumer-plugin</artifactId>
            <version>1.0.0</version>
        </dependency>
        <dependency>
            <groupId>com.pufferfishscheduler.plugin</groupId>
            <artifactId>pfs-rabbitmqproducer-plugin</artifactId>
            <version>1.0.0</version>
        </dependency>

    </dependencies>

    <build>
        <!-- plugins/pfs-dataclean-plugin-1.0.0/** 由下方 antrun 在 process-resources 阶段
            直接从源码目录复制到 plugins/steps/，不走标准 resources 阶段，
            避免这些 JAR 被打进 Spring Boot fat-WAR 的 WEB-INF/classes -->
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <excludes>
                    <exclude>plugins/pfs-dataclean-plugin-1.0.0/**</exclude>
                    <exclude>plugins/pfs-debeziumjson-plugin-1.0.0/**</exclude>
                    <exclude>plugins/pfs-filter-plugin-1.0.0/**</exclude>
                    <exclude>plugins/pfs-ftpdownload-plugin-1.0.0/**</exclude>
                    <exclude>plugins/pfs-ftpupload-plugin-1.0.0/**</exclude>
                    <exclude>plugins/pfs-doris-plugin-1.0.0/**</exclude>
                    <exclude>plugins/pfs-kafkaconsumer-plugin-1.0.0/**</exclude>
                    <exclude>plugins/pfs-kafkaproducer-plugin-1.0.0/**</exclude>
                    <exclude>plugins/pfs-rabbitmqconsumer-plugin-1.0.0/**</exclude>
                    <exclude>plugins/pfs-rabbitmqproducer-plugin-1.0.0/**</exclude>
                </excludes>
            </resource>
        </resources>
        <plugins>
            <!-- 将数据清洗插件从源码目录直接复制到 classpath 的 plugins/steps/ 供 Kettle 扫描
                 阶段：process-resources（早于 compile），mvn compile 即可触发 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <executions>
                    <execution>
                        <id>copy-dataclean-plugin</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <mkdir dir="${project.build.outputDirectory}/plugins/steps/pfs-dataclean-plugin-1.0.0"/>
                                <!-- 清理可能残留的根部游离 jar（会触发 Kettle jar-plugin 注册，与 plugin.xml 冲突） -->
                                <delete file="${project.build.outputDirectory}/plugins/pfs-dataclean-plugin-1.0.0.jar"
                                        quiet="true"/>
                                <!-- 直接从源码目录复制，不依赖插件子工程的 ZIP 分发包 -->
                                <copy todir="${project.build.outputDirectory}/plugins/steps/pfs-dataclean-plugin-1.0.0"
                                      overwrite="true">
                                    <fileset
                                            dir="${project.basedir}/src/main/resources/plugins/pfs-dataclean-plugin-1.0.0"/>
                                </copy>
                            </target>
                        </configuration>
                    </execution>
                    <execution>
                        <id>copy-debeziumjson-plugin</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <mkdir dir="${project.build.outputDirectory}/plugins/steps/pfs-debeziumjson-plugin-1.0.0"/>
                                <delete file="${project.build.outputDirectory}/plugins/pfs-debeziumjson-plugin-1.0.0.jar"
                                        quiet="true"/>
                                <copy todir="${project.build.outputDirectory}/plugins/steps/pfs-debeziumjson-plugin-1.0.0"
                                      overwrite="true">
                                    <fileset
                                            dir="${project.basedir}/src/main/resources/plugins/pfs-debeziumjson-plugin-1.0.0"/>
                                </copy>
                            </target>
                        </configuration>
                    </execution>
                    <execution>
                        <id>copy-filter-plugin</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <mkdir dir="${project.build.outputDirectory}/plugins/steps/pfs-filter-plugin-1.0.0"/>
                                <delete file="${project.build.outputDirectory}/plugins/pfs-filter-plugin-1.0.0.jar"
                                        quiet="true"/>
                                <copy todir="${project.build.outputDirectory}/plugins/steps/pfs-filter-plugin-1.0.0"
                                      overwrite="true">
                                    <fileset
                                            dir="${project.basedir}/src/main/resources/plugins/pfs-filter-plugin-1.0.0"/>
                                </copy>
                            </target>
                        </configuration>
                    </execution>
                    <execution>
                        <id>copy-ftpdownload-plugin</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <mkdir dir="${project.build.outputDirectory}/plugins/steps/pfs-ftpdownload-plugin-1.0.0"/>
                                <delete file="${project.build.outputDirectory}/plugins/pfs-ftpdownload-plugin-1.0.0.jar"
                                        quiet="true"/>
                                <copy todir="${project.build.outputDirectory}/plugins/steps/pfs-ftpdownload-plugin-1.0.0"
                                      overwrite="true">
                                    <fileset
                                            dir="${project.basedir}/src/main/resources/plugins/pfs-ftpdownload-plugin-1.0.0"/>
                                </copy>
                            </target>
                        </configuration>
                    </execution>
                    <execution>
                        <id>copy-ftpupload-plugin</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <mkdir dir="${project.build.outputDirectory}/plugins/steps/pfs-ftpupload-plugin-1.0.0"/>
                                <delete file="${project.build.outputDirectory}/plugins/pfs-ftpupload-plugin-1.0.0.jar"
                                        quiet="true"/>
                                <copy todir="${project.build.outputDirectory}/plugins/steps/pfs-ftpupload-plugin-1.0.0"
                                      overwrite="true">
                                    <fileset
                                            dir="${project.basedir}/src/main/resources/plugins/pfs-ftpupload-plugin-1.0.0"/>
                                </copy>
                            </target>
                        </configuration>
                    </execution>
                    <execution>
                        <id>copy-doris-plugin</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <mkdir dir="${project.build.outputDirectory}/plugins/steps/pfs-doris-plugin-1.0.0"/>
                                <delete file="${project.build.outputDirectory}/plugins/pfs-doris-plugin-1.0.0.jar"
                                        quiet="true"/>
                                <copy todir="${project.build.outputDirectory}/plugins/steps/pfs-doris-plugin-1.0.0"
                                      overwrite="true">
                                    <fileset
                                            dir="${project.basedir}/src/main/resources/plugins/pfs-doris-plugin-1.0.0"/>
                                </copy>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <executions>
                    <execution>
                        <id>unpack-kettle-kafka-plugins</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>unpack</goal>
                        </goals>
                        <configuration>
                            <artifactItems>
                                <artifactItem>
                                    <groupId>com.pufferfishscheduler.plugin</groupId>
                                    <artifactId>pfs-kafkaconsumer-plugin</artifactId>
                                    <version>1.0.0</version>
                                    <type>zip</type>
                                    <overWrite>true</overWrite>
                                    <outputDirectory>${project.build.outputDirectory}/plugins/steps</outputDirectory>
                                </artifactItem>
                                <artifactItem>
                                    <groupId>com.pufferfishscheduler.plugin</groupId>
                                    <artifactId>pfs-kafkaproducer-plugin</artifactId>
                                    <version>1.0.0</version>
                                    <type>zip</type>
                                    <overWrite>true</overWrite>
                                    <outputDirectory>${project.build.outputDirectory}/plugins/steps</outputDirectory>
                                </artifactItem>
                                <artifactItem>
                                    <groupId>com.pufferfishscheduler.plugin</groupId>
                                    <artifactId>pfs-rabbitmqconsumer-plugin</artifactId>
                                    <version>1.0.0</version>
                                    <type>zip</type>
                                    <overWrite>true</overWrite>
                                    <outputDirectory>${project.build.outputDirectory}/plugins/steps</outputDirectory>
                                </artifactItem>
                                <artifactItem>
                                    <groupId>com.pufferfishscheduler.plugin</groupId>
                                    <artifactId>pfs-rabbitmqproducer-plugin</artifactId>
                                    <version>1.0.0</version>
                                    <type>zip</type>
                                    <overWrite>true</overWrite>
                                    <outputDirectory>${project.build.outputDirectory}/plugins/steps</outputDirectory>
                                </artifactItem>
                            </artifactItems>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <mainClass>com.pufferfishscheduler.worker.WorkerApplication</mainClass>
                    <!-- Java 17+：Dubbo 3.x 用 Javassist 生成 adaptive 类需打开 java.base，否则 MetricsReporterFactory 初始化失败 -->
                    <jvmArguments>--add-opens java.base/java.lang=ALL-UNNAMED --add-opens
                        java.base/java.lang.reflect=ALL-UNNAMED --add-opens
                        java.base/sun.net.www.protocol.jar=ALL-UNNAMED
                    </jvmArguments>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>